{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "npx wrangler dev --env=dev --local",
    "deploy": "npx wrangler deploy --minify",
    "cf-typegen": "npx wrangler types --env-interface CloudflareBindings",
    "lint": "npx eslint .",
    "test": "vitest run --config vitest.integration.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.15",
    "@types/node": "^24.12.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.83.0"
  }
}
